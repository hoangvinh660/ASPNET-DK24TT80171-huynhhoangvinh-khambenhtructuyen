<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Phong Kham Online</title>
    @Styles.Render("~/Content/css")
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary fixed-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="@Url.Action("Index", "TrangChu")">Phong Kham Online</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "TrangChu")">Trang chu</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Chuyen khoa</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Bac si</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Tin tuc</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Dat lich</a></li>
                </ul>
                <ul class="navbar-nav">
                    <li class="nav-item"><a class="nav-link" href="#">Tai khoan</a></li>
                </ul>
            </div>
        </div>
    </nav>
    <main class="container body-content">
        @RenderBody()
        <hr />
        <footer class="footer text-center">
            <p>&copy; @DateTime.Now.Year - Phong Kham Online - Do an sinh vien</p>
        </footer>
    </main>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>