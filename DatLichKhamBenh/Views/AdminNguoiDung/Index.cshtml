@model List<DatLichKhamBenh.Models.NguoiDung>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var vaiTroLoc = ViewBag.VaiTro as string;
    var tuKhoa = ViewBag.TuKhoa as string;
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small">Tìm theo tên / email / username</label>
                <input type="text" name="tuKhoa" value="@tuKhoa" class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Vai trò</label>
                <select name="vaiTro" class="form-select form-select-sm">
                    <option value="">Tất cả</option>
                    <option value="Admin" selected="@(vaiTroLoc == "Admin")">Admin</option>
                    <option value="BacSi" selected="@(vaiTroLoc == "BacSi")">Bác sĩ</option>
                    <option value="BenhNhan" selected="@(vaiTroLoc == "BenhNhan")">Bệnh nhân</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i> Lọc</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm w-100">Xóa lọc</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Tên đăng nhập</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>SĐT</th>
                    <th>Vai trò</th>
                    <th>Ngày tạo</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td>@u.MaNguoiDung</td>
                        <td><code>@u.TenDangNhap</code></td>
                        <td>@u.HoTen</td>
                        <td><small>@u.Email</small></td>
                        <td><small>@(u.SoDienThoai ?? "—")</small></td>
                        <td>
                            @switch (u.VaiTro)
                            {
                                case "Admin": <span class="badge bg-danger">Admin</span> break;
                                case "BacSi": <span class="badge bg-primary">Bác sĩ</span> break;
                                case "BenhNhan": <span class="badge bg-success">Bệnh nhân</span> break;
                                default: <span class="badge bg-secondary">@u.VaiTro</span> break;
                            }
                        </td>
                        <td><small>@u.NgayTao.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            @if (u.DaKhoa)
                            {
                                <span class="badge bg-danger">Đã khóa</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Sua" asp-route-id="@u.MaNguoiDung" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DoiTrangThaiKhoa" method="post" class="d-inline"
                                  onsubmit="return confirm('@(u.DaKhoa ? "Mở khóa" : "Khóa") tài khoản này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.MaNguoiDung" />
                                <button type="submit" class="btn btn-sm btn-outline-warning" title="@(u.DaKhoa ? "Mở khóa" : "Khóa")">
                                    <i class="bi @(u.DaKhoa ? "bi-unlock" : "bi-lock")"></i>
                                </button>
                            </form>
                            <form asp-action="Xoa" method="post" class="d-inline"
                                  onsubmit="return confirm('Xóa tài khoản này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.MaNguoiDung" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted">Không có người dùng nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
