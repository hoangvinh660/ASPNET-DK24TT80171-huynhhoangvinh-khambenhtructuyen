@{
    var hoTen = User.Identity?.IsAuthenticated == true
        ? (User.FindFirst("HoTen")?.Value ?? User.Identity?.Name)
        : null;
    var vaiTro = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Đặt lịch khám bệnh</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DatLichKhamBenh.styles.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-primary mb-3 shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="TrangChu" asp-action="Index">
                    <i class="bi bi-hospital"></i> Đặt lịch khám bệnh
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="TrangChu" asp-action="Index">
                                <i class="bi bi-house-fill"></i> Trang chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="ChuyenKhoa" asp-action="Index">
                                <i class="bi bi-grid"></i> Chuyên khoa
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="BacSi" asp-action="Index">
                                <i class="bi bi-person-vcard"></i> Bác sĩ
                            </a>
                        </li>
                        @if (vaiTro == "BenhNhan")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="LichHen" asp-action="LichHenCuaToi">
                                    <i class="bi bi-calendar-check"></i> Lịch hẹn của tôi
                                </a>
                            </li>
                        }
                        @if (vaiTro == "BacSi")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="BacSiLichHen" asp-action="Index">
                                    <i class="bi bi-calendar-week"></i> Lịch hẹn của tôi
                                </a>
                            </li>
                        }
                        @if (vaiTro == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Admin/Dashboard/Index">
                                    <i class="bi bi-speedometer2"></i> Quản trị
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userMenu" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i> @hoTen
                                    <span class="badge bg-light text-primary ms-1">@vaiTro</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                    <li>
                                        <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TaiKhoan" asp-action="DangNhap">
                                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="TaiKhoan" asp-action="DangKy">
                                    <i class="bi bi-person-plus-fill"></i> Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        @if (TempData["ThongBao"] is string thongBao)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill"></i> @thongBao
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        @if (TempData["LoiThongBao"] is string loiThongBao)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i> @loiThongBao
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-4 py-4">
        <div class="container">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    <div class="fw-semibold text-primary">
                        <i class="bi bi-hospital"></i> Hệ thống đặt lịch khám bệnh
                    </div>
                    <small class="text-muted">Đồ án tốt nghiệp - 2026</small>
                </div>
                <div class="col-md-6 text-md-end">
                    <small>
                        <a href="/TrangChu/Privacy" class="me-3">
                            <i class="bi bi-shield-lock"></i> Chính sách bảo mật
                        </a>
                        <a href="mailto:admin@datlichkhambenh.local">
                            <i class="bi bi-envelope"></i> Liên hệ
                        </a>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
