@model DatLichKhamBenh.Models.ViewModels.BacSiAdminViewModel
@{
    ViewData["Title"] = "Thêm bác sĩ";
}

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Tao" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

            <h6 class="text-muted">Tài khoản</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="TenDangNhap" class="form-label">Tên đăng nhập</label>
                    <input asp-for="TenDangNhap" class="form-control" />
                    <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="MatKhau" class="form-label">Mật khẩu</label>
                    <input asp-for="MatKhau" type="password" class="form-control" />
                    <span asp-validation-for="MatKhau" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HoTen" class="form-label">Họ và tên</label>
                    <input asp-for="HoTen" class="form-control" />
                    <span asp-validation-for="HoTen" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="SoDienThoai" class="form-label">Số điện thoại</label>
                    <input asp-for="SoDienThoai" class="form-control" />
                    <span asp-validation-for="SoDienThoai" class="text-danger"></span>
                </div>
            </div>

            <hr />
            <h6 class="text-muted">Hồ sơ bác sĩ</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="MaChuyenKhoa" class="form-label">Chuyên khoa</label>
                    <select asp-for="MaChuyenKhoa" asp-items="ViewBag.DsChuyenKhoa" class="form-select">
                        <option value="">-- Chọn chuyên khoa --</option>
                    </select>
                    <span asp-validation-for="MaChuyenKhoa" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HocVi" class="form-label">Học vị</label>
                    <input asp-for="HocVi" class="form-control" placeholder="Ví dụ: Thạc sĩ - Bác sĩ" />
                    <span asp-validation-for="HocVi" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="GiaKham" class="form-label">Giá khám (VND)</label>
                    <input asp-for="GiaKham" type="number" class="form-control" />
                    <span asp-validation-for="GiaKham" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HinhAnh" class="form-label">Đường dẫn ảnh</label>
                    <input asp-for="HinhAnh" class="form-control" placeholder="/images/bacsi/default.png" />
                </div>
                <div class="col-12">
                    <label asp-for="KinhNghiem" class="form-label">Kinh nghiệm</label>
                    <input asp-for="KinhNghiem" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="MoTa" class="form-label">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
