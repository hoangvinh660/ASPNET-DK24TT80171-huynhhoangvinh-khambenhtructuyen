@model List<DatLichKhamBenh.Models.ChuyenKhoa>
@{
    ViewData["Title"] = "Danh sách chuyên khoa";
}

<h2 class="mb-4"><i class="bi bi-grid-fill text-primary"></i> Danh sách chuyên khoa</h2>

<div class="row g-3">
    @foreach (var ck in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-start gap-3">
                        <i class="bi bi-clipboard2-pulse text-primary" style="font-size: 2.5rem;"></i>
                        <div class="flex-grow-1">
                            <h5 class="mb-1">@ck.TenChuyenKhoa</h5>
                            <small class="text-muted">@ck.DanhSachBacSi.Count bác sĩ</small>
                            <p class="text-muted mt-2 mb-2 small">@(ck.MoTa ?? "Chưa có mô tả.")</p>
                            <a asp-action="ChiTiet" asp-route-id="@ck.MaChuyenKhoa" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-arrow-right-circle"></i> Xem bác sĩ
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Chưa có chuyên khoa nào.</div>
}
