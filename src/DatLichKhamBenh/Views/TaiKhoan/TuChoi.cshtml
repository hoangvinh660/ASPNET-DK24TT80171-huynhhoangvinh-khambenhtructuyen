@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body p-4 text-center">
                <h2 class="text-danger mb-3">
                    <i class="bi bi-shield-exclamation"></i> Truy cập bị từ chối
                </h2>
                <p class="lead">Bạn không có quyền truy cập trang này.</p>
                <p class="text-muted">Có thể tài khoản của bạn không được cấp đủ quyền hoặc bạn cần đăng nhập bằng tài khoản khác.</p>
                <a asp-controller="TrangChu" asp-action="Index" class="btn btn-primary mt-2">
                    <i class="bi bi-house-fill"></i> Về trang chủ
                </a>
            </div>
        </div>
    </div>
</div>
