@model DatLichKhamBenh.Models.BacSi
@{
    ViewData["Title"] = $"{Model.HocVi} {Model.NguoiDung?.HoTen}";
}

@functions {
    string DinhDangVnd(decimal tien) => string.Format("{0:N0} ₫", tien);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="TrangChu" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Bác sĩ</a></li>
        <li class="breadcrumb-item active">@Model.NguoiDung?.HoTen</li>
    </ol>
</nav>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <div class="row">
            <div class="col-md-3 text-center">
                <partial name="_BacSiAvatar" model="Model.HinhAnh"
                         view-data='new ViewDataDictionary(ViewData) { { "AvatarSize", "160px" }, { "AvatarClass", "rounded-circle object-fit-cover border shadow-sm" } }' />
            </div>
            <div class="col-md-9">
                <h2 class="mb-1">@Model.HocVi @Model.NguoiDung?.HoTen</h2>
                <p class="mb-1">
                    <span class="badge bg-primary fs-6">
                        <i class="bi bi-clipboard2-pulse"></i> @Model.ChuyenKhoa?.TenChuyenKhoa
                    </span>
                </p>
                <p class="text-muted mb-3"><i class="bi bi-briefcase"></i> @Model.KinhNghiem</p>

                <h5 class="mt-3">Giới thiệu</h5>
                <p>@(Model.MoTa ?? "Chưa có giới thiệu chi tiết.")</p>

                <div class="row mt-3">
                    <div class="col-md-6">
                        <div class="border rounded p-3">
                            <div class="text-muted small">Giá khám</div>
                            <div class="h4 text-success mb-0">@DinhDangVnd(Model.GiaKham)</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded p-3">
                            <div class="text-muted small">Liên hệ</div>
                            <div><i class="bi bi-envelope"></i> @Model.NguoiDung?.Email</div>
                            <div><i class="bi bi-telephone"></i> @(Model.NguoiDung?.SoDienThoai ?? "—")</div>
                        </div>
                    </div>
                </div>

                <a asp-controller="LichHen" asp-action="DatLich" asp-route-maBacSi="@Model.MaBacSi"
                   class="btn btn-success btn-lg mt-4">
                    <i class="bi bi-calendar-plus"></i> Đặt lịch khám với bác sĩ này
                </a>
            </div>
        </div>
    </div>
</div>
