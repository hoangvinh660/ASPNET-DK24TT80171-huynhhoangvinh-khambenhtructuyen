@model DatLichKhamBenh.Models.ChuyenKhoa
@{
    ViewData["Title"] = Model.TenChuyenKhoa;
}

@functions {
    string DinhDangVnd(decimal tien) => string.Format("{0:N0} ₫", tien);
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="TrangChu" asp-action="Index">Trang chủ</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Chuyên khoa</a></li>
        <li class="breadcrumb-item active">@Model.TenChuyenKhoa</li>
    </ol>
</nav>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h2><i class="bi bi-clipboard2-pulse text-primary"></i> @Model.TenChuyenKhoa</h2>
        <p class="text-muted mb-0">@(Model.MoTa ?? "Chưa có mô tả.")</p>
    </div>
</div>

<h4 class="mb-3">Bác sĩ trong chuyên khoa (@Model.DanhSachBacSi.Count)</h4>

<div class="row g-3">
    @foreach (var bs in Model.DanhSachBacSi)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex gap-3">
                        <partial name="_BacSiAvatar" model="bs.HinhAnh"
                                 view-data='new ViewDataDictionary(ViewData) { { "AvatarSize", "64px" } }' />
                        <div class="flex-grow-1">
                            <h6 class="mb-0">@bs.HocVi @bs.NguoiDung?.HoTen</h6>
                            <div class="text-muted small">@bs.KinhNghiem</div>
                            <div class="text-success fw-bold mt-1">@DinhDangVnd(bs.GiaKham) / lần khám</div>
                            <div class="d-flex gap-2 mt-2">
                                <a asp-controller="BacSi" asp-action="ChiTiet" asp-route-id="@bs.MaBacSi" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-info-circle"></i> Chi tiết
                                </a>
                                <a asp-controller="LichHen" asp-action="DatLich" asp-route-maBacSi="@bs.MaBacSi" class="btn btn-sm btn-success">
                                    <i class="bi bi-calendar-plus"></i> Đặt lịch
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
@if (!Model.DanhSachBacSi.Any())
{
    <div class="alert alert-info">Chưa có bác sĩ nào trong chuyên khoa này.</div>
}
